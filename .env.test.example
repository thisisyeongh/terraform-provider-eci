# Copy this file to .env.test and fill in the values.
# Then run: source .env.test && make testacc
#
# WARNING: .env.test is gitignored. Never commit real credentials.
# For CI, store these as GitHub Secrets.

# Provider authentication (required for all acceptance tests)
export TF_ACC=1
export ECI_API_ACCESS_TOKEN=""
export ECI_API_ENDPOINT="https://portal.elice.cloud/api/"
